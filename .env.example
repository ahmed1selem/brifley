# Briefley — Environment Variables
# Copy this file to .env and fill in your values.

# ScrapeOps API key for rotating browser headers
SCRAPEOPS_API_KEY=

# Qdrant vector database connection
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Together.ai API key for RAG chatbot (Milestone 5)
TOGETHER_API_KEY=

# HDBSCAN tuning parameter for cluster distance
HDBSCAN_EPSILON=8.54187817e-12

# Telegram MTProto API Credentials (for ingestion)
# Get these from https://my.telegram.org
TG_API_ID=
TG_API_HASH=
TG_PHONE=
